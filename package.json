{
  "name": "sticky-notes",
  "version": "2.0.0",
  "description": "本地便签工具 — 多窗口桌面便签应用",
  "main": "main.js",
  "author": "tips",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:dir": "electron-builder --dir"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.tips.stickynotes",
    "productName": "便签工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "control.html"
    ],
    "publish": {
      "provider": "github",
      "owner": "mistergram",
      "repo": "sticky-notes"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "便签工具"
    }
  }
}
